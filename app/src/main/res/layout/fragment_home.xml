<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/feedlot"
    tools:context=".view.fragments.HomeFragment"
    >

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_tablet_mixer_home_adapter"
        android:layout_width="420dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="50dp"
        android:layout_marginTop="50dp"
        android:layout_marginBottom="50dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
    <TextView
        android:id="@+id/tv_peso"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:textSize="32sp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:visibility="gone"
        />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_sync"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/rule_settings_24px"
        android:backgroundTint="@color/green_500_dark"
        android:layout_marginStart="@dimen/_5sdp"
        android:layout_marginBottom="@dimen/_5sdp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:focusable="false"
        android:clickable="true"/>


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_admin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/dashboard_2_gear_24px"
        android:backgroundTint="@color/green_500_dark"
        android:layout_marginStart="@dimen/_26sdp"
        android:layout_marginBottom="@dimen/_5sdp"
        app:layout_constraintStart_toEndOf="@id/btn_sync"
        app:layout_constraintBottom_toBottomOf="parent"
        android:focusable="false"
        android:clickable="true"/>

</androidx.constraintlayout.widget.ConstraintLayout>